# Copy to .env and fill in values
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxx

# Optional - voice line for arrival demo. Server returns a string regardless.
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# When true, all Claude API calls return canned demo responses.
# Use for offline rehearsal or if the API key is unavailable.
DEMO_MODE=true

# HMAC secret used to sign dispute briefs. Demo only.
HAP_SIGNING_SECRET=rosewood-heart-warden-demo-secret-do-not-use-in-prod
